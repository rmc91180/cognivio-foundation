GRAFANA_CLOUD_PROMETHEUS_REMOTE_WRITE_URL=https://prometheus-prod-00-prod-us-central-0.grafana.net/api/prom/push
GRAFANA_CLOUD_PROMETHEUS_USERNAME=123456
GRAFANA_CLOUD_API_KEY=<set-in-railway-or-secret-store>
COGNIVIO_MONITORING_ENV=staging
COGNIVIO_METRICS_TARGET=<staging-backend-host>
COGNIVIO_METRICS_SCHEME=https
COGNIVIO_METRICS_PATH=/metrics
COGNIVIO_METRICS_SCRAPE_INTERVAL=30s
COGNIVIO_METRICS_SCRAPE_TIMEOUT=10s
