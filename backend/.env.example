# MongoDB connection string
# For Railway, use the MongoDB Atlas connection string
MONGO_URL="mongodb+srv://user:password@cluster.mongodb.net"

# Database name
DB_NAME="cognivio"

# CORS origins (comma-separated list of allowed origins)
# In production, set to your frontend URL
CORS_ORIGINS="https://your-frontend.railway.app"

# JWT secret key (generate a secure random string for production)
JWT_SECRET="your-secure-jwt-secret-key"

# Emergent LLM API key (optional - server handles absence gracefully)
EMERGENT_LLM_KEY="your-emergent-llm-key"
# Dashboard leadership insight cache TTL in seconds (0 disables cache)
LEADERSHIP_INSIGHTS_CACHE_TTL_SECONDS=1800

# Demo mode (fixed demo users, registration disabled)
DEMO_MODE=false

# Admin emails (comma-separated list)
ADMIN_EMAILS="principal@demo.cognivio.app"

# Frontend URL for report links
FRONTEND_URL="https://your-frontend.railway.app"

# Curriculum adherence weighting (0-1)
ADHERENCE_WEIGHT=0.15

# S3 storage configuration
S3_BUCKET="your-s3-bucket"
S3_REGION="us-east-1"
S3_ENDPOINT=""
S3_PUBLIC_BASE_URL=""
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
