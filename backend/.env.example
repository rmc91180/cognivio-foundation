# MongoDB connection string
# For Railway, use the MongoDB Atlas connection string
MONGO_URL="mongodb+srv://user:password@cluster.mongodb.net"

# Database name
DB_NAME="cognivio"

# CORS origins (comma-separated list of allowed origins)
# In production, set to your frontend URL
CORS_ORIGINS="https://your-frontend.railway.app"

# JWT secret key (generate a secure random string for production)
JWT_SECRET="your-secure-jwt-secret-key"

# Real video analysis model configuration
OPENAI_API_KEY="your-openai-api-key"
OPENAI_VISION_MODEL="gpt-4.1-mini"
VIDEO_ANALYSIS_MAX_FRAMES=6
SMART_FRAME_SELECTION_ENABLED=false
SMART_FRAME_SELECTION_VERSION="smart_frames_v1"
VIDEO_ANALYSIS_FRAME_SCAN_FPS=1
VIDEO_ANALYSIS_MIN_FRAME_GAP_SEC=8
VIDEO_ANALYSIS_ENABLE_OCR_SIGNALS=false
SMART_MOMENT_SAMPLING_ENABLED=true
SMART_MOMENT_SAMPLING_VERSION="lesson_moments_v1"
VIDEO_ANALYSIS_WINDOW_SEC=20
VIDEO_ANALYSIS_MAX_MOMENTS=6
AUDIO_ANALYSIS_ENABLED=false
AUDIO_TRANSCRIPTION_ENABLED=false
AUDIO_FEATURES_ENABLED=false
AUDIO_TRANSCRIPTION_MODEL="gpt-4o-mini-transcribe"
AUDIO_TRANSCRIPTION_LANGUAGE=""
AUDIO_TRANSCRIPT_RETENTION_DAYS=30
AUDIO_ALLOW_STUDENT_VOICE_PROCESSING=false
PAID_ANALYSIS_ENABLED=false
PAID_ANALYSIS_ALLOWLIST_EMAILS="principal@demo.cognivio.app,teacher@demo.cognivio.app"

# Legacy Emergent LLM API key (optional fallback path)
EMERGENT_LLM_KEY="your-emergent-llm-key"
# Dashboard leadership insight cache TTL in seconds (0 disables cache)
LEADERSHIP_INSIGHTS_CACHE_TTL_SECONDS=1800

# Demo mode (fixed demo users, registration disabled)
DEMO_MODE=false

# Admin emails (comma-separated list)
ADMIN_EMAILS="principal@demo.cognivio.app"

# Pilot access approval flow
ACCESS_APPROVAL_REQUIRED=true
ACCESS_APPROVAL_NOTIFY_EMAIL="rmc91180@gmail.com"
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Cognivio <login@cognivio.live>"
RESEND_API_BASE_URL="https://api.resend.com"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="rmc91180@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM_EMAIL="rmc91180@gmail.com"
SMTP_USE_TLS=true

# Frontend URL for report links
FRONTEND_URL="https://your-frontend.railway.app"
BACKEND_PUBLIC_BASE_URL="https://your-backend.railway.app"
UPLOAD_DIR="/data/uploads"

# Curriculum adherence weighting (0-1)
ADHERENCE_WEIGHT=0.15

# Privacy profile requirements for teacher video uploads
PRIVACY_REQUIRE_PROFILE=true
PRIVACY_PROFILE_MIN_REFERENCES=3
PRIVACY_PROFILE_MAX_REFERENCES=5
PRIVACY_MANUAL_REVIEW_ENABLED=true
PRIVACY_ALLOW_BLUR_ALL_FALLBACK=true
PRIVACY_ALLOW_DEGRADED_RUNTIME=false
PRIVACY_WORKER_COUNT=1
PRIVACY_MAX_RETRIES=3
PRIVACY_TEACHER_MATCH_THRESHOLD=0.9
PRIVACY_AMBIGUOUS_MATCH_THRESHOLD=0.8
PRIVACY_RAW_VIDEO_RETENTION_DAYS=30
PRIVACY_PROFILE_IMAGE_RETENTION_DAYS=30
PRIVACY_PURGE_INTERVAL_MINUTES=60

# Recognition and exemplar eligibility
RECOGNITION_FIVE_STAR_SCORE_MIN=9.0

# S3 storage configuration
S3_BUCKET="your-s3-bucket"
S3_REGION="us-east-1"
S3_ENDPOINT=""
S3_PUBLIC_BASE_URL=""
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
