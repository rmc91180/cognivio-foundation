{
  "name": "cognivio",
  "version": "1.0.0",
  "description": "Cognivio production stack orchestration",
  "private": true,
  "scripts": {
    "dev:mvp": "concurrently \"npm run dev:backend:mvp\" \"npm run dev:frontend:mvp\"",
    "dev:frontend:mvp": "npm run start --prefix frontend",
    "dev:backend:mvp": "python -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload --app-dir backend",
    "build:frontend:mvp": "npm run build --prefix frontend",
    "test:backend:mvp": "python -m pytest backend/tests -q",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "ci:backend": "python -m pytest backend/tests -q",
    "ci:frontend": "npm run build --prefix frontend"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
